# Copy this file to .env and fill in real values.
# .env is gitignored; this template is committed.

# Local Postgres connection string. Format:
#   postgresql://<user>[:<password>]@<host>:<port>/<dbname>?schema=public
# Example for Postgres.app on macOS with current user:
DATABASE_URL="postgresql://your_user@localhost:5432/kudos_board?schema=public"

# CORS allow-list: Vite default dev origin
FRONTEND_ORIGIN="http://localhost:5173"

# Express port
PORT=3000

# Secret for signing/verifying JWTs. Use a long random string (>=32 chars).
# Generate with: `openssl rand -base64 48`
JWT_SECRET="change-me-to-a-long-random-string"
